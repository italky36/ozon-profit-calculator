{
  "name": "claude",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -kn api,web,admin -c green,blue,magenta \"tsx watch server/index.ts\" \"wait-on -t 30000 tcp:3001 && vite\" \"wait-on -t 30000 tcp:3001 && vite --config vite.config.sysadmin.ts\"",
    "dev:lan": "cross-env HOST=0.0.0.0 concurrently -kn api,web,admin -c green,blue,magenta \"tsx watch server/index.ts\" \"wait-on -t 30000 tcp:3001 && vite --host\" \"wait-on -t 30000 tcp:3001 && vite --config vite.config.sysadmin.ts --host\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:sysadmin": "vite --config vite.config.sysadmin.ts",
    "start": "tsx server/index.ts",
    "build": "tsc -b && vite build && vite build --config vite.config.sysadmin.ts",
    "build:web": "tsc -b && vite build",
    "build:sysadmin": "vite build --config vite.config.sysadmin.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:extract": "node scripts/extract-data.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:create-admin": "node scripts/create-admin.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@hono/node-ws": "^1.3.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@vitest/ui": "^4.1.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.16",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.21.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5",
    "web-push": "^3.6.7",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  }
}
