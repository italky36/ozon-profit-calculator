# .env for production deploy on the server. Copy to /opt/profitcontrol/.env
# alongside docker-compose.yml. DO NOT commit the filled version anywhere.

# --- Postgres ---
# Internal-only credentials (db not exposed to host). Generate fresh on first
# deploy; rotate by changing here and `docker compose up -d db` then app.
PG_USER=app
PG_DB=ozon_calc
PG_PASSWORD=replace_me_with_random_32_bytes

# --- App ---
# Public URL of the main SPA. Used to build links in invite/verify/reset
# emails. Must match exactly (scheme + host, no trailing slash).
APP_URL=https://app.profitcontrol.io

# Session cookie name (any string; only matters if you run multiple deployments
# behind the same domain).
SESSION_COOKIE_NAME=ozon_calc_session

# --- First sysadmin (seed) ---
# Created on first `docker compose up` if the users table is empty. Change
# the password right after first login through the sysadmin UI.
ADMIN_EMAIL=remy51984@outlook.com
ADMIN_PASSWORD=replace_me_with_random_password

# --- TURN/STUN (coturn) ---
# Public IP коробки — coturn говорит клиентам, куда обращаться за relay.
# Domain тоже работает, но IP надёжнее (нет DNS round-trip на старте звонка).
TURN_EXTERNAL_IP=72.56.9.220
TURN_REALM=profitcontrol.io
TURN_USERNAME=profitcontrol
TURN_PASSWORD=replace_me_with_random_password
# Эти же значения seed.mjs запишет в ice_servers при первом запуске, если
# таблица пустая. На production-сервере НЕ открывайте TURN наружу без
# username/password — coturn без -lt-cred-mech превращается в open-relay
# для DDoS amplification.
