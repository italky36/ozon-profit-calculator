# Backend auth — shared secret expected in `X-Auth-Token` header.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AUTH_TOKEN=replace-me-with-long-random-string

# Frontend reads this token at build/dev time and sends it on every API call.
# Must match AUTH_TOKEN above (single-tenant).
VITE_AUTH_TOKEN=replace-me-with-long-random-string

# SQLite file. Relative paths are resolved from project root.
DB_PATH=data/app.db

# Backend HTTP port. Vite dev proxies /api to this URL.
PORT=3001
SERVER_URL=http://localhost:3001

# Phase 2 — Ozon Seller API credentials (used by import endpoints).
# OZON_CLIENT_ID=
# OZON_API_KEY=
