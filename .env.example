# Postgres connection string. Production / dev-with-docker.
# Local dev container: `docker run -d --name ozon-pg -p 5433:5432 \
#   -e POSTGRES_PASSWORD=… -e POSTGRES_DB=ozon_calc postgres:16-alpine`
DATABASE_URL=postgresql://postgres:password@localhost:5433/ozon_calc

# Legacy SQLite file (will be removed after Postgres cutover is complete).
# Kept for the ETL transition window so scripts can read the old DB.
DB_PATH=data/app.db

# Backend HTTP port. Vite dev proxies /api to this URL.
PORT=3001
SERVER_URL=http://localhost:3001

# === Multi-user auth ===
# Public URL of the frontend — used in verification email links.
APP_URL=http://localhost:5173
# Cookie name for the session token. HTTP-only, sent on every /api/* request.
SESSION_COOKIE_NAME=ozon_calc_session

# SMTP for verification emails. If any of these is missing, emails are
# logged to stdout instead of sent (dev fallback).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@example.com

# Initial admin credentials seeded by `npm run db:seed` (only when the users
# table is empty). Override these BEFORE the first seed run for a real deploy.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
